# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
# dependencies
/node_modules
/deps
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results
/blob-report
/playwright/.cache

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.local.example

# netlify (local state + build artifacts)
.netlify
/public/build-info.json

# vercel
.vercel

# pipeline agent artifacts
.pipeline

# tool memory
.workbuddy/

# pnpm artifact directories
nm_temp/
node_modules_broken/
node_modules_old*/
node_modules_phantom*/

# mcp config (project-specific, should be configured per developer)
.mcp.json

# python cache
__pycache__/
*.pyc

# typescript
*.tsbuildinfo
next-env.d.ts

# perf reports (HTML 体积大，仅提交 JSON 摘要)
docs/perf/*.html
.lighthouseci/

# local embed / tunnel / env migrate secrets & logs (never commit)
.embed-api-key.local
.embed-tunnel-url.local
.cloudflared-tunnel.log
.cloudflared-tunnel.err.log
.vercel-env-migrate.local.json
.vercel-env-merged.local.json
.embed-server.err.log
.embed-server.out.log
.next-dev.err.log
.next-dev.out.log
scripts/_embed.err.txt
scripts/_embed.out.txt
scripts/_next.err.txt
scripts/_next.out.txt
