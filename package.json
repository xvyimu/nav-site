{
  "name": "nav-site",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "dev": "next dev -p 3264 --webpack",
    "build": "node scripts/write-build-info.mjs && next build --webpack",
    "start": "next start",
    "setup": "node scripts/setup-env.mjs",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:quality": "vitest run tests/search-quality.test.ts --reporter=verbose",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "analyze": "ANALYZE=true next build --webpack",
    "audit:security": "pnpm audit --registry=https://registry.npmjs.org --audit-level moderate",
    "bulk:add": "node scripts/bulk-add.mjs",
    "resource:ingest": "node scripts/resource-ingest/run.mjs",
    "resource:ingest:dry-run": "node scripts/resource-ingest/run.mjs --source devto --limit 20",
    "check:links": "node scripts/check-links.mjs --report",
    "db:reviews:apply": "node scripts/apply-reviews-migration.mjs",
    "db:reviews:apply:dry-run": "node scripts/apply-reviews-migration.mjs --dry-run",
    "db:reviews:verify": "node scripts/verify-reviews-migration.mjs",
    "verify:production": "node scripts/probe-production.mjs",
    "verify:production:latest": "node scripts/probe-production.mjs --expect-embedding-skipped",
    "verify:launch-readiness": "node scripts/check-launch-readiness.mjs",
    "typecheck": "tsc --noEmit --incremental false"
  },
  "dependencies": {
    "next-auth": "5.0.0-beta.31",
    "@sentry/nextjs": "^10.59.0",
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "2.108.2",
    "fuse.js": "^7.4.2",
    "lucide-react": "1.20.0",
    "motion": "12.40.0",
    "next": "16.2.9",
    "next-themes": "0.4.6",
    "pangu": "^7.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "2.0.7",
    "tw-animate-css": "1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.9",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "shadcn": "4.11.0",
    "tailwindcss": "^4",
    "typescript": "^5.1.0",
    "vitest": "^4.1.9"
  }
}
