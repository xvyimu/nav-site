# ============================================================
# 综合导航站 — 环境变量模板
#
# 使用方法：
#   cp .env.local.example .env.local
#   然后填入实际值
# ============================================================

# ── Supabase ──
# 从 Supabase Dashboard → Settings → API 获取
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Auth.js ──
# 生成方式：openssl rand -base64 32
AUTH_SECRET=your-auth-secret

# ── 管理员密码 ──
# 推荐：scrypt 哈希（Auth.js Credentials）
# 生成：node scripts/hash-admin-password.mjs "your-password"
# 配置 HASH 后可删除明文 ADMIN_PASSWORD
ADMIN_PASSWORD_HASH=
# 过渡兼容：仅当未设置 ADMIN_PASSWORD_HASH 时使用明文 timingSafeEqual
ADMIN_PASSWORD=your-admin-password

# ── GitHub OAuth（可选，用户登录）──
# 从 GitHub Settings → Developer settings → OAuth Apps 创建
# Callback URL: https://your-domain/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=

# ── Supabase Service Role Key（可选，服务端绕过 RLS）──
# 从 Supabase Dashboard → Settings → API 获取
# SUPABASE_SERVICE_ROLE_KEY_PROD 优先级高于 SUPABASE_SERVICE_ROLE_KEY，用于生产库 service role
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SERVICE_ROLE_KEY_PROD=

# ── 语义搜索 embedding 服务（可选）──
# 本地 loopback（开发默认）：
EMBED_SERVER_URL=http://127.0.0.1:18003
# 生产远程 HTTPS（同一 BGE 512 模型；必须 HTTPS + API Key）：
# 当前生产入口（Worker 反代 Named Tunnel → 本机 18003）：
# EMBED_SERVER_URL=https://nav-site-embed-proxy.xiej4352.workers.dev
# EMBED_SERVER_API_KEY=generate-a-long-random-secret
# 仅调试：在 serverless 上强制探测 loopback（生产不要开）
# EMBED_SERVER_LOOPBACK_ENABLED=true

# ── 资源库（可选，/resources 页面）──
# RESOURCE_LIBRARY_API_KEY 是 rl 项目 Edge Function 调用 key，仅服务端使用
# RESOURCE_LIBRARY_ANON_KEY 用于资源库公开读路径（配合 scripts/migration-resource-library-public-read.sql）
# RESOURCE_LIBRARY_SERVICE_ROLE_KEY 仅服务端使用，用于公开读 fallback 和评分提交
RESOURCE_LIBRARY_API_KEY=
RESOURCE_LIBRARY_ANON_KEY=
RESOURCE_LIBRARY_PUBLIC_PAGES_SOURCE=public_pages
RESOURCE_LIBRARY_PUBLIC_RATING_STATS_RPC=get_public_resource_rating_count
RESOURCE_LIBRARY_SERVICE_ROLE_KEY=

# ── 分布式限流 Upstash Redis REST（可选，S2）──
# 高 QPS 公开端点（search / favicon / resource-search）跨实例限流。
# 未配置时回退进程内桶（单实例有效）。从 Upstash Console → REST API 获取。
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── 分布式限流（可选，S2）──
# 高 QPS 公开端点（search / favicon / resource-search）在 Vercel 多实例下
# 进程内限流形同虚设。配置 Upstash Redis REST 后跨实例共享，真正生效；
# 未配置则自动回退进程内桶（单实例仍有效，不阻断部署）。
# 从 Upstash Console → Redis → REST API 获取
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Sentry（可选）──
# 从 Sentry Dashboard → Settings → Client Keys 获取
NEXT_PUBLIC_SENTRY_DSN=

# ── Stripe（可选，付费功能预留）──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── 旧库（已废弃，单库模式后不再需要）──
# ADR-001 已合并双库为单库，以下变量仅保留用于历史脚本兼容
SOURCE_SUPABASE_URL=
SOURCE_SUPABASE_ANON_KEY=
