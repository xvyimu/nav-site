# ============================================================
# 综合导航站 — 环境变量模板
#
# 使用方法：
#   cp .env.local.example .env.local
#   然后填入实际值
# ============================================================

# ── Supabase ──
# 从 Supabase Dashboard → Settings → API 获取
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Auth.js ──
# 生成方式：openssl rand -base64 32
AUTH_SECRET=your-auth-secret

# ── 管理员密码 ──
# 用于 /api/admin/login 和 Auth.js authorize 回调
ADMIN_PASSWORD=your-admin-password

# ── GitHub OAuth（可选，用户登录）──
# 从 GitHub Settings → Developer settings → OAuth Apps 创建
# Callback URL: https://your-domain/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=

# ── Supabase Service Role Key（可选，服务端绕过 RLS）──
# 从 Supabase Dashboard → Settings → API 获取
# SUPABASE_SERVICE_ROLE_KEY_PROD 优先级高于 SUPABASE_SERVICE_ROLE_KEY，用于生产库 service role
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SERVICE_ROLE_KEY_PROD=

# ── 语义搜索（可选，本地 embedding 服务）──
EMBED_SERVER_URL=http://127.0.0.1:8003

# ── 资源库（可选，/resources 页面）──
# RESOURCE_LIBRARY_API_KEY 是 rl 项目 Edge Function 调用 key，仅服务端使用
# RESOURCE_LIBRARY_ANON_KEY 用于资源库公开读路径（配合 scripts/migration-resource-library-public-read.sql）
# RESOURCE_LIBRARY_SERVICE_ROLE_KEY 仅服务端使用，用于公开读 fallback 和评分提交
RESOURCE_LIBRARY_API_KEY=
RESOURCE_LIBRARY_ANON_KEY=
RESOURCE_LIBRARY_PUBLIC_PAGES_SOURCE=public_pages
RESOURCE_LIBRARY_PUBLIC_RATING_STATS_RPC=get_public_resource_rating_count
RESOURCE_LIBRARY_SERVICE_ROLE_KEY=

# ── Sentry（可选）──
# 从 Sentry Dashboard → Settings → Client Keys 获取
NEXT_PUBLIC_SENTRY_DSN=

# ── Stripe（可选，付费功能预留）──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── 旧库（已废弃，单库模式后不再需要）──
# ADR-001 已合并双库为单库，以下变量仅保留用于历史脚本兼容
SOURCE_SUPABASE_URL=
SOURCE_SUPABASE_ANON_KEY=
