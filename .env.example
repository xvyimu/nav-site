# 环境变量模板（兼容入口）
# 权威完整模板：cp .env.local.example .env.local
# Auth / Admin / Embed / 资源库 / Sentry 见 .env.local.example

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
AUTH_SECRET=your-auth-secret
ADMIN_PASSWORD_HASH=
# 仅本地开发可临时用明文；生产必须 HASH
# ADMIN_PASSWORD=

NEXT_PUBLIC_SITE_URL=https://yuanjia1314.ccwu.cc

# 资源库仅服务端 key，禁止 NEXT_PUBLIC_ 前缀
# RESOURCE_LIBRARY_API_KEY=
# RESOURCE_LIBRARY_ANON_KEY=
# RESOURCE_LIBRARY_SERVICE_ROLE_KEY=

# 远程 embed
# EMBED_SERVER_URL=https://nav-site-embed-proxy.xiej4352.workers.dev
# EMBED_SERVER_API_KEY=

# Cloudflare Workers AI embed（可选 · S3 · nav 语义搜索 1024-d）
# EMBED_PROVIDER=cloudflare
# CF_ACCOUNT_ID=
# CF_AI_API_TOKEN=
# EMBED_DIM=1024
# EMBED_SEMANTIC_RPC=search_links_semantic_v2

# 生产探针可选：embedding 必须 ok
# HEALTH_REQUIRE_EMBEDDING=1

# ── 分布式限流（可选 · S2）──
# 生产多实例应配置 URL+TOKEN：/api/search /api/favicon /api/resource-search /api/tools
# /api/web-vitals 走 Upstash Redis 跨实例限流；未配置则回退进程内桶（单实例仍有效）。
# Upstash → REST，天然契合 serverless。fail-closed 是独立 opt-in，勿默认开启。
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# 生产可选硬化：仅当 Upstash 已配置且希望故障时拒绝分布式限流路径时设 1。
# 生效条件：NODE_ENV=production 或 VERCEL=1，且 DISTRIBUTED_RATE_LIMIT_FAIL_CLOSED=1。
# 未配置 Upstash 时开启会导致公开限流路径 429，且 /api/health 的 distributedRateLimit=error → 503。
# DISTRIBUTED_RATE_LIMIT_FAIL_CLOSED=0

# 生产 smoke 强制 embedding 健康（S2）：设 1 时 embedding 非 ok 即判失败
# HEALTH_REQUIRE_EMBEDDING=1        # 服务端 /api/health 侧
# PRODUCTION_REQUIRE_EMBEDDING=1    # probe-production 侧；或 CLI --require-embedding

# 支付 API 桩默认隐藏；仅实现真实 checkout/webhook 后才可启用
ENABLE_PAYMENTS_API=0
